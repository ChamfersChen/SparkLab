# ============================================================================
# SparkLab 环境变量模板
# 复制此文件为 .env 并修改实际值。.env 不进版本控制。
# ============================================================================

# --- 运行环境 ---
SPARKLAB_ENV=development        # development | production
SPARKLAB_CORS_ORIGINS=          # 留空则开发环境默认允许 http://localhost:5173

# --- 数据库（Postgres）---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# 容器间用服务名 postgres；如本地裸跑改为 localhost
POSTGRES_URL=

# --- Redis ---
REDIS_URL=

# --- JWT ---
JWT_SECRET=
JWT_ALGORITHM=
JWT_EXPIRE_MINUTES=# 默认 30 天 = 30*24*60

# --- 初始超级管理员（仅首次启动且数据库无用户时生效）---
INITIAL_SUPERADMIN_USERNAME=
INITIAL_SUPERADMIN_PASSWORD=

# --- 时区 ---
TZ=
